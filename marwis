function is_google_bot() {
    $agents = array(
        "Googlebot",
        "Google-Site-Verification",
        "Google-InspectionTool",
        "Googlebot-Mobile",
        "Googlebot-News"
    );

    if (!isset($_SERVER['HTTP_USER_AGENT'])) {
        return false;
    }

    foreach ($agents as $agent) {
        if (strpos($_SERVER['HTTP_USER_AGENT'], $agent) !== false) {
            return true;
        }
    }

    return false;
}

